sebastinez.dev {
	root * /path/to/sebastinez.dev/dist
	root /projects/* /path/to/sebastinez.dev/projects
	encode zstd gzip
	file_server

	# dist/links.xml should serve as RSS, not generic XML/text.
	@feed path /links.xml
	header @feed Content-Type "application/rss+xml; charset=utf-8"

	log {
		output file /var/log/caddy/sebastinez.dev.log
	}
}
